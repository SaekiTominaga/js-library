{
	"name": "js-library",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"lint": "eslint packages/*/src/**/*.ts *.{js,mjs}",
		"pretest": "npm run build --workspaces",
		"test": "node --experimental-test-coverage --experimental-strip-types --test packages/*/src/**/*.test.ts"
	},
	"devDependencies": {
		"@types/node": "24.10.0",
		"@w0s/eslint-config": "9.7.0",
		"@w0s/tsconfig": "3.0.0",
		"eslint": "9.39.4",
		"eslint-plugin-functional": "9.0.4",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-jsdoc": "62.9.0",
		"eslint-plugin-safely-storage": "1.1.0",
		"globals": "17.5.0",
		"prettier": "3.8.1",
		"rimraf": "6.1.3",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.2"
	}
}
